# Optional: use Pexels for free stock photos and Reel videos.
# Get a key from https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: override the Chrome binary used for PNG rendering.
CHROME_BIN=google-chrome

# Required only when you are ready to publish through the Instagram Graph API.
IG_USER_ID=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=

# Optional: delay between public Reel -> feed -> Story posts.
# Default is 300000 ms, which is 5 minutes.
PUBLISH_FORMAT_GAP_MS=300000
REQUIRED_STORY_COUNT=5
# Default 7-day block on publishing an already used topic again.
INSTAGRAM_DUPLICATE_TOPIC_WINDOW_MS=604800000

# Free Reel source. "pexels" uses Pexels stock video when available and falls
# back to the image slideshow. "pexels-required" blocks if no stock video is found.
# "slideshow" keeps the old card-based Reel.
REEL_SOURCE=pexels

# Optional: bake licensed background music into the Reel MP4 before upload.
# Use a local file path or an HTTPS URL. Keep the volume low for spa-style BGM.
# Also set a license plus either a title or a source URL so the track is traceable.
REEL_AUDIO_PATH=
REEL_AUDIO_URL=
# For n8n Cloud, upload licensed music to Cloudinary as a video resource and
# set this public ID. Use `npm run upload:reel-audio -- --audio path-or-url`.
REEL_AUDIO_CLOUDINARY_PUBLIC_ID=
REEL_AUDIO_VOLUME=0.18
REEL_AUDIO_TITLE=
REEL_AUDIO_CREATOR=
REEL_AUDIO_SOURCE_URL=
REEL_AUDIO_LICENSE=
REEL_AUDIO_CREDIT=

# Do not require n8n API access for the free setup. Use GitHub Actions schedule
# as the cloud runner so automation can run while the local PC is off.

# Required for publishing media through Cloudinary.
CLOUDINARY_CLOUD_NAME=

# Optional: use unsigned uploads for slide images:
CLOUDINARY_UPLOAD_PRESET=

# Required for Reel/video generation and uploads:
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional, only if adding an OpenAI-based caption/compliance review node in n8n.
OPENAI_API_KEY=
